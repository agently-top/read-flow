# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# FreshRSS 配置
FRESHRSS_URL=http://host.docker.internal:8081
FRESHRSS_USER=admin
FRESHRSS_PASSWORD=FreshRSS2026!

# 后端 API 配置
BACKEND_URL=http://localhost:3001
PORT=3001
DATABASE_URL=/app/data/readflow.db

# 管理员密码（用于后台管理）
ADMIN_PASSWORD=your_admin_password_here

# GLM API 配置（必需，用于 AI 摘要和分类）
# 获取地址：https://open.bigmodel.cn/usercenter/apikeys
GLM_API_KEY=your_glm_api_key_here

# 飞书推送（可选）
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 思源笔记（可选）
SIYUAN_API_URL=http://host.docker.internal:6806
SIYUAN_NOTEBOOK_ID=20250805163218-dqifw69

# 前端配置
NEXT_PUBLIC_API_URL=http://localhost:3001
PORT=3000
